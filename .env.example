# Backend environment — local development (DynamoDB Local + Redis)
# Template

# Redis
REDIS_URL=redis://redis:6379

# AWS / DynamoDB Local
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
DYNAMODB_ENDPOINT_URL=http://localstack:4566
KINESIS_ENDPOINT_URL=http://localstack:4566

# Resource names
KINESIS_STREAM_NAME=need-a-sidekick-events
DYNAMODB_TABLE_NAME=activity_metrics
S3_BUCKET_NAME=need-a-sidekick-archive

# Lobby settings
LOBBY_TTL_SECONDS=900
DEFAULT_RADIUS_METERS=10
MAX_RADIUS_METERS=100
